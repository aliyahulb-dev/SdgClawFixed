<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_dashboard_sheet.xml
    Background for the Stability Dashboard bottom sheet.
    Rounded top corners, flat bottom so it aligns with the screen edge.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners
        android:topLeftRadius="16dp"
        android:topRightRadius="16dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />

    <!-- Slightly lighter than surface_dark so the sheet stands out -->
    <solid android:color="#1E2130" />

    <stroke
        android:width="1dp"
        android:color="#2A2F45" />

</shape>
