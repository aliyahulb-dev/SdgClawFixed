<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the code-snippet card inside the Bridge Setup wizard.
    Slightly darker than the card background with a distinct left-accent border.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base rounded rectangle fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/code_block_bg" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Left accent stripe (4 dp wide) -->
    <item android:right="0dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_blue" />
            <corners android:topLeftRadius="8dp" android:bottomLeftRadius="8dp" />
            <size android:width="4dp" />
        </shape>
    </item>

</layer-list>
