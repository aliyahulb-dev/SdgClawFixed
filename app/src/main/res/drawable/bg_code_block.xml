<?xml version="1.0" encoding="utf-8"?>
<!--
  bg_code_block.xml
  Dark background with rounded corners used for command/code snippet cards.
  Slightly darker than card_bg to visually distinguish the code block.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FF141414" />
    <corners android:radius="10dp" />
    <stroke
        android:width="1dp"
        android:color="@color/gray_medium" />
</shape>
