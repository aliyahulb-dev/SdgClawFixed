<?xml version="1.0" encoding="utf-8"?>
<!--
  Rounded-rectangle background for a "done" status badge chip.
  Used in BridgeSetupActivity step rows once a step is verified successfully.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#14532D" />

    <stroke
        android:width="1dp"
        android:color="#166534" />

    <corners android:radius="12dp" />

</shape>
