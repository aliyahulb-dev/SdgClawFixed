<?xml version="1.0" encoding="utf-8"?>
<!--
  Rounded-rectangle background for an "error" status badge chip.
  Used in BridgeSetupActivity step rows when a step check fails.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#450A0A" />

    <stroke
        android:width="1dp"
        android:color="#7F1D1D" />

    <corners android:radius="12dp" />

</shape>
