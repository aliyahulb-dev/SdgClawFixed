<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base theme ────────────────────────────────────────────────────── -->
    <style name="Theme.SDGClaw" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/gray_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="colorError">@color/red_error</item>
        <item name="android:statusBarColor">@color/card_bg</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <!-- ── NoActionBar variant (used by all Activities) ──────────────────── -->
    <style name="Theme.SDGClaw.NoActionBar" parent="Theme.SDGClaw">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
