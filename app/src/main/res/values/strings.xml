    <!-- Bridge setup terminal commands -->
    <string name="bridge_cmd_1">pkg install nodejs</string>
    <string name="bridge_cmd_2">mkdir -p ~/sdgclaw-bridge &amp;&amp; cd ~/sdgclaw-bridge</string>
    <string name="bridge_cmd_3">npm init -y &amp;&amp; npm install ws</string>
    <string name="bridge_cmd_4">node ~/sdgclaw-bridge/server.js</string>

