    <!-- ── BridgeSetupActivity — Step 1: Install Termux ─────────────────── -->
    <string name="setup_step1_title">Install Termux</string>
    <string name="setup_step1_desc">SDG Claw uses a Node.js WebSocket server running inside Termux to
execute shell commands on your device.\n\nInstall Termux from F-Droid (not the Play Store — the Play Store
version is outdated and lacks package management).\n\n1. Open F-Droid on your device.\n2. Search for
"Termux".\n3. Install and open it at least once so it initialises its package database.</string>

    <!-- ── BridgeSetupActivity — Step 2: Install Node.js ────────────────── -->
    <string name="setup_step2_title">Install Node.js in Termux</string>
    <string name="setup_step2_desc">Open Termux and run the following commands to update the package
list and install Node.js.\n\nThis may take a few minutes depending on your internet speed.</string>
    <string name="setup_step2_code">pkg update -y &amp;&amp; pkg upgrade -y &amp;&amp; pkg install nodejs -y</string>

    <!-- ── BridgeSetupActivity — Step 3: Copy setup script ───────────────── -->
    <string name="setup_step3_title">Prepare Setup Script</string>
    <string name="setup_step3_desc">The SDG Claw setup script will now be copied to your device storage.
This script creates the bridge directory, writes the Node.js server file, installs the required
npm package, and starts the server.\n\nNo action needed — the copy happens automatically. The path
will appear below once complete.</string>

    <!-- ── BridgeSetupActivity — Step 4: Run setup.sh ────────────────────── -->
    <string name="setup_step4_title">Run the Setup Script in Termux</string>
    <string name="setup_step4_desc">Termux will open automatically. Copy and paste the command below
into the Termux terminal, then press Enter.\n\nThe script will:\n• Create ~/sdgclaw-bridge/\n•
Write server.js\n• Run npm install ws\n• Start the WebSocket server on port 8765\n\nOnce the script
is running you will see "[SDG Claw Bridge] Listening on ws://127.0.0.1:8765".</string>
    <!-- %s will be replaced at runtime with the actual path from filesDir -->
    <string name="setup_step4_code">bash &lt;path-to-setup.sh&gt;</string>

    <!-- ── BridgeSetupActivity — Step 5: Verify connection ───────────────── -->
    <string name="setup_step5_title">Verify Connection</string>
    <string name="setup_step5_desc">Keep the Termux session open with the server running, then tap
"Verify Connection" below.\n\nSDG Claw will attempt to connect to the bridge at
ws://127.0.0.1:8765 and report the result.\n\nIf the connection fails:\n• Ensure the Termux
terminal shows the "[SDG Claw Bridge] Listening" message.\n• Try running the server manually with
the command below.\n• Make sure no firewall or VPN is blocking 127.0.0.1:8765.</string>
    <string name="setup_step5_code">node ~/sdgclaw-bridge/server.js</string>

