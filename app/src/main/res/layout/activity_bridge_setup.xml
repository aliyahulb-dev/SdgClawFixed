<?xml version="1.0" encoding="utf-8"?>
<!--
    Bridge Setup Wizard — activity_bridge_setup.xml
    Hosts a step-indicator, scrollable content area, code-snippet block,
    action buttons, and a connection-verification status row.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark"
    tools:context=".BridgeSetupActivity">

    <!-- ── Top bar ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/bridge_setup_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_medium"
            android:textSize="14sp"
            tools:text="Step 1 / 6" />

    </LinearLayout>

    <!-- ── Dot indicator ───────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/dot_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:paddingBottom="16dp" />

    <!-- ── Scrollable content ──────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Step title -->
            <TextView
                android:id="@+id/tv_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"
                tools:text="Install Termux" />

            <!-- Step description -->
            <TextView
                android:id="@+id/tv_step_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp"
                tools:text="Download and install Termux from F-Droid." />

            <!-- Code block card (hidden when no snippet) -->
            <LinearLayout
                android:id="@+id/card_code_block"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_code_block"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Code text -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_code_snippet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textColor="@color/code_text"
                        android:textSize="13sp"
                        android:textIsSelectable="true"
                        tools:text="pkg install nodejs" />

                </HorizontalScrollView>

                <!-- Copy-code button -->
                <Button
                    android:id="@+id/btn_copy_code"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/btn_copy_code"
                    android:textColor="@color/accent_blue"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- "Copy setup.sh to storage" action button (step 3 only) -->
            <Button
                android:id="@+id/btn_copy_script"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/btn_copy_script"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Verification status row (final step only) -->
            <LinearLayout
                android:id="@+id/verify_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/iv_verify_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="10dp"
                    tools:src="@drawable/circle_green"
                    android:contentDescription="@string/verify_icon_desc" />

                <TextView
                    android:id="@+id/tv_verify_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    tools:text="Connected successfully!" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Bottom navigation buttons ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="16dp"
        android:background="@color/surface_dark">

        <Button
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_back"
            android:textColor="@color/gray_medium" />

        <Button
            android:id="@+id/btn_next"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_next" />

    </LinearLayout>

</LinearLayout>
