<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_bridge_setup.xml
  Layout for the BridgeSetupActivity step-by-step wizard.

  Structure:
  ┌─────────────────────────────────────────────┐
  │  Toolbar (title + back arrow)               │
  ├─────────────────────────────────────────────┤
  │  Step indicator (dots)                      │
  │  Step counter label  (e.g. "Step 2 of 5")  │
  ├─────────────────────────────────────────────┤
  │  ScrollView                                 │
  │    Step title                               │
  │    Step description                         │
  │    [Code snippet card]  (optional)          │
  │      monospace code  +  Copy button         │
  │    [Script path card]   (optional)          │
  │    [Poll status text]   (optional)          │
  │    [Connection status card] (final step)    │
  ├─────────────────────────────────────────────┤
  │  Back ──────────────────────── Next/Finish  │
  └─────────────────────────────────────────────┘
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark">

    <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/card_bg"
        android:elevation="4dp"
        app:title="@string/setup_title"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="@string/setup_btn_back" />

    <!-- ── Step indicator + counter ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:elevation="2dp">

        <!-- Dot indicators -->
        <LinearLayout
            android:id="@+id/step_indicator_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

        <!-- Step counter label -->
        <TextView
            android:id="@+id/tv_step_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="@string/setup_step_counter_placeholder" />

    </LinearLayout>

    <!-- ── Scrollable step content ───────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Step title -->
            <TextView
                android:id="@+id/tv_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2"
                android:text="@string/setup_step1_title" />

            <!-- Step description -->
            <TextView
                android:id="@+id/tv_step_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/setup_step1_desc" />

            <!-- ── Code snippet card (GONE when no snippet for current step) ── -->
            <LinearLayout
                android:id="@+id/card_code_snippet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:background="@drawable/bg_code_block"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_code_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <!-- Monospace code -->
                <TextView
                    android:id="@+id/tv_code_snippet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/code_text"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:selectAllOnFocus="true"
                    android:textIsSelectable="true" />

                <!-- Copy button -->
                <Button
                    android:id="@+id/btn_copy_code"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/setup_btn_copy_code"
                    android:textColor="@color/accent_blue"
                    android:backgroundTint="@android:color/transparent" />

            </LinearLayout>

            <!-- ── Script path card (shown after successful copy on step 3) ─ -->
            <LinearLayout
                android:id="@+id/card_script_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_script_path_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_script_path"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/green_connected"
                    android:textSize="12sp"
                    android:textIsSelectable="true"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- ── Poll / progress status text ─────────────────────────── -->
            <TextView
                android:id="@+id/tv_poll_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:gravity="center"
                android:visibility="gone" />

            <!-- ── Connection status card (final step only) ─────────────── -->
            <LinearLayout
                android:id="@+id/card_connection_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_connection_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/circle_gray"
                    android:contentDescription="@string/setup_connection_icon_desc" />

                <TextView
                    android:id="@+id/tv_connection_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:text="@string/setup_connection_waiting" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Bottom navigation bar ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/card_bg"
        android:elevation="8dp"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/setup_btn_back"
            android:textColor="@color/text_secondary" />

        <Button
            android:id="@+id/btn_next"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/setup_btn_next"
            android:backgroundTint="@color/accent_blue" />

    </LinearLayout>

</LinearLayout>
