<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_chat.xml
    Root is a CoordinatorLayout so BottomSheetBehavior works correctly.
    The stability dashboard is a persistent BottomSheet anchored to the bottom.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <!-- ═══════════════════════════════════════════════════════════════════════
         Main chat content (Toolbar + RecyclerView + input bar)
         We wrap this in an AppBarLayout + nested scroll so the bottom sheet
         can slide over the content without clipping.
    ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/card_bg"
            android:elevation="4dp"
            app:title="SDG Claw"
            app:titleTextColor="@android:color/white" />

        <!-- Message list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:paddingTop="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_message" />

        <!-- Typing indicator -->
        <LinearLayout
            android:id="@+id/typingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● ● ●"
                android:textColor="@color/gray_medium"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Agent is thinking…"
                android:textColor="@color/gray_medium"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Input bar -->
        <LinearLayout
            android:id="@+id/inputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_bg"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:hint="Message…"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"
                android:textColor="@android:color/white"
                android:textColorHint="@color/gray_medium"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="bottom"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Send"
                android:src="@android:drawable/ic_menu_send"
                android:tint="@color/colorPrimary" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Stability Dashboard — persistent BottomSheet
         Starts HIDDEN; revealed automatically when the first diagnostic fires.
    ═══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/stabilityDashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dashboard_sheet"
        android:orientation="vertical"
        app:behavior_hideable="true"
        app:behavior_peekHeight="@dimen/dashboard_peek_height"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Drag handle / title row -->
        <TextView
            android:id="@+id/tvDashboardHandle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="⬆ Stability Dashboard"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gray_dark" />

        <!-- Chip row: regime, sScore, drift, entropy -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDiag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp"
            app:chipSpacingHorizontal="6dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRegime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Regime"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:chipBackgroundColor="@color/chip_unknown"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.Material3.Chip.Assist" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S: —"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:chipBackgroundColor="@color/gray_dark"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.Material3.Chip.Assist" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDrift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drift: —"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:chipBackgroundColor="@color/gray_dark"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.Material3.Chip.Assist" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEntropy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H̄: —"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:chipBackgroundColor="@color/gray_dark"
                app:chipStrokeWidth="0dp"
                style="@style/Widget.Material3.Chip.Assist" />

        </com.google.android.material.chip.ChipGroup>

        <!-- ASCII sparkline of drift series -->
        <TextView
            android:id="@+id/tvSparkline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:paddingHorizontal="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:text="─"
            android:textColor="@color/gray_medium"
            android:textSize="18sp"
            tools:text="▁▂▃▄▅▆▇█▇▆▅▄  steps=10" />

        <!-- Regime detail text -->
        <TextView
            android:id="@+id/tvRegimeDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="10dp"
            android:textColor="@color/gray_medium"
            android:textSize="11sp"
            tools:text="drift bounded (0.012–0.345), no state recurrence found" />

        <!-- Force Stop button — only visible for diverging / chaotic regimes -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForceStop"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:text="⛔ Force Stop Agent"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:backgroundTint="@color/chip_diverging" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
