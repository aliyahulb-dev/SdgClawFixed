<?xml version="1.0" encoding="utf-8"?>
<!--
  MainActivity layout — home screen for SDG Claw.

  Shows:
    • App title + subtitle
    • Live connection status dot + label
    • "Set Up Bridge" nudge (visible only when bridge is disconnected)
    • Action buttons: Test Connection, Settings, Start Chat
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingTop="64dp"
    android:paddingEnd="32dp"
    android:paddingBottom="32dp"
    tools:context=".MainActivity">

    <!-- ── App identity ──────────────────────────────────────────────────── -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textColor="@color/text_primary"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/main_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />

    <!-- ── Connection status row ─────────────────────────────────────────── -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/circle_red"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/status_disconnected"
            android:textColor="@color/status_disconnected"
            android:textSize="14sp"
            tools:text="@string/status_connected" />

    </LinearLayout>

    <!-- ── Bridge-disconnected nudge ─────────────────────────────────────── -->
    <!--   Visibility toggled in MainActivity.updateConnectionStatus()        -->

    <TextView
        android:id="@+id/tvBridgeHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card"
        android:drawablePadding="10dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:text="@string/bridge_disconnected_hint"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="visible"
        tools:visibility="visible" />

    <Button
        android:id="@+id/btnSetupBridge"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/gray_dark"
        android:text="@string/btn_setup_bridge"
        android:textColor="@color/accent_blue"
        android:textSize="14sp"
        android:visibility="visible"
        style="@style/Widget.Material3.Button.OutlinedButton"
        tools:visibility="visible" />

    <!-- ── Spacer to push action buttons towards the bottom ─────────────── -->

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ── Primary action buttons ────────────────────────────────────────── -->

    <Button
        android:id="@+id/btnTestConnection"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/gray_dark"
        android:text="@string/btn_test_connection"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        style="@style/Widget.Material3.Button" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/gray_dark"
        android:text="@string/btn_settings"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        style="@style/Widget.Material3.Button" />

    <Button
        android:id="@+id/btnChat"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="@color/accent_blue"
        android:text="@string/btn_chat"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        style="@style/Widget.Material3.Button" />

</LinearLayout>
