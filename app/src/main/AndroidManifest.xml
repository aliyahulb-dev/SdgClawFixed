<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.sdgclaw">

    <!-- ── Permissions ──────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--
      Android 11+ (API 30+) package visibility:
      We need to query whether Termux is installed and launch it by package name.
      The <queries> block below declares intent visibility without needing
      QUERY_ALL_PACKAGES, which requires Play Store declaration.
    -->
    <queries>
        <!-- Termux package launch -->
        <package android:name="com.termux" />
        <!-- termux://run-script URI scheme (deep-link) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="termux" />
        </intent>
    </queries>

    <application
        android:name=".SDGClawApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SDGClaw">

        <!-- ── Activities ─────────────────────────────────────────────── -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SDGClaw.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.SDGClaw.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.SDGClaw.NoActionBar" />

        <!--
          BridgeSetupActivity — step-by-step guide for connecting the
          Termux WebSocket bridge.  Navigated to from MainActivity when
          the bridge is not connected.
        -->
        <activity
            android:name=".BridgeSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.SDGClaw.NoActionBar"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity" />
        </activity>

    </application>

</manifest>
